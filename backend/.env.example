# Postgres (from infra/docker-compose.yml)
DATABASE_URL=postgresql+psycopg://app:app@localhost:5432/livemap

# Strava OAuth
STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret
STRAVA_REDIRECT_URI=http://127.0.0.1:5173/auth/strava/callback
STRAVA_SCOPES=read,activity:read_all
AUTH_SUCCESS_REDIRECT_URL=http://127.0.0.1:5173/
SESSION_SECRET=replace-with-a-random-secret
SESSION_COOKIE_NAME=srq_session
SESSION_COOKIE_SECURE=false
SESSION_MAX_AGE_SECONDS=2592000

# Runtime (container-friendly defaults)
APP_HOST=0.0.0.0
APP_PORT=8000
WEB_CONCURRENCY=2
LOG_LEVEL=info
GUNICORN_TIMEOUT=60

# Optional error monitoring
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
